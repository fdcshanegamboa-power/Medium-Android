<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="@color/background">

    <!-- Avatar + stats row -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- Avatar circle -->
        <View
            android:id="@+id/skeleton_avatar"
            android:layout_width="86dp"
            android:layout_height="86dp"
            android:background="@drawable/shimmer_circle"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"/>

        <!-- Posts stat -->
        <LinearLayout
            android:id="@+id/skeleton_posts"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            app:layout_constraintTop_toTopOf="@id/skeleton_avatar"
            app:layout_constraintBottom_toBottomOf="@id/skeleton_avatar"
            app:layout_constraintStart_toEndOf="@id/skeleton_avatar"
            app:layout_constraintEnd_toStartOf="@id/skeleton_followers">

            <View
                android:layout_width="32dp"
                android:layout_height="14dp"
                android:background="@drawable/shimmer_bg"
                android:layout_marginBottom="6dp"/>

            <View
                android:layout_width="48dp"
                android:layout_height="10dp"
                android:background="@drawable/shimmer_bg"/>

        </LinearLayout>

        <!-- Followers stat -->
        <LinearLayout
            android:id="@+id/skeleton_followers"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            app:layout_constraintTop_toTopOf="@id/skeleton_avatar"
            app:layout_constraintBottom_toBottomOf="@id/skeleton_avatar"
            app:layout_constraintStart_toEndOf="@id/skeleton_posts"
            app:layout_constraintEnd_toStartOf="@id/skeleton_following">

            <View
                android:layout_width="32dp"
                android:layout_height="14dp"
                android:background="@drawable/shimmer_bg"
                android:layout_marginBottom="6dp"/>

            <View
                android:layout_width="56dp"
                android:layout_height="10dp"
                android:background="@drawable/shimmer_bg"/>

        </LinearLayout>

        <!-- Following stat -->
        <LinearLayout
            android:id="@+id/skeleton_following"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            app:layout_constraintTop_toTopOf="@id/skeleton_avatar"
            app:layout_constraintBottom_toBottomOf="@id/skeleton_avatar"
            app:layout_constraintStart_toEndOf="@id/skeleton_followers"
            app:layout_constraintEnd_toEndOf="parent">

            <View
                android:layout_width="32dp"
                android:layout_height="14dp"
                android:background="@drawable/shimmer_bg"
                android:layout_marginBottom="6dp"/>

            <View
                android:layout_width="56dp"
                android:layout_height="10dp"
                android:background="@drawable/shimmer_bg"/>

        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Display name -->
    <View
        android:layout_width="140dp"
        android:layout_height="12dp"
        android:background="@drawable/shimmer_bg"
        android:layout_marginTop="16dp"/>

    <!-- Bio line 1 -->
    <View
        android:layout_width="match_parent"
        android:layout_height="10dp"
        android:background="@drawable/shimmer_bg"
        android:layout_marginTop="8dp"/>

    <!-- Bio line 2 -->
    <View
        android:layout_width="200dp"
        android:layout_height="10dp"
        android:background="@drawable/shimmer_bg"
        android:layout_marginTop="6dp"/>

    <!-- Button -->
    <View
        android:layout_width="match_parent"
        android:layout_height="42dp"
        android:background="@drawable/shimmer_bg"
        android:layout_marginTop="12dp"/>

</LinearLayout>