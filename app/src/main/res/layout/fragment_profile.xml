<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/app_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/background"
        app:elevation="0dp">

        <!-- Toolbar with username -->
        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:theme="@style/ToolbarTheme"
            android:background="@color/background">

            <TextView
                android:id="@+id/tv_username"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/foreground"
                android:fontFamily="@font/instagram_sans"/>

        </androidx.appcompat.widget.Toolbar>

        <!-- Profile info — not collapsing, stays visible -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:background="@color/background">

            <!-- Profile pic + stats row -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <de.hdodenhof.circleimageview.CircleImageView
                    android:id="@+id/iv_profile_image"
                    android:layout_width="86dp"
                    android:layout_height="86dp"
                    app:civ_border_width="2dp"
                    app:civ_border_color="@color/purple_400"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toStartOf="parent"/>

                <!-- Posts -->
                <LinearLayout
                    android:id="@+id/ll_posts"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    app:layout_constraintTop_toTopOf="@id/iv_profile_image"
                    app:layout_constraintBottom_toBottomOf="@id/iv_profile_image"
                    app:layout_constraintStart_toEndOf="@id/iv_profile_image"
                    app:layout_constraintEnd_toStartOf="@id/ll_followers">

                    <TextView
                        android:id="@+id/tv_post_count"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/foreground"
                        android:fontFamily="@font/instagram_sans"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Posts"
                        android:textSize="12sp"
                        android:textColor="@color/foreground"
                        android:fontFamily="@font/instagram_sans"/>

                </LinearLayout>

                <!-- Followers -->
                <LinearLayout
                    android:id="@+id/ll_followers"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:clickable="true"
                    android:focusable="true"
                    app:layout_constraintTop_toTopOf="@id/iv_profile_image"
                    app:layout_constraintBottom_toBottomOf="@id/iv_profile_image"
                    app:layout_constraintStart_toEndOf="@id/ll_posts"
                    app:layout_constraintEnd_toStartOf="@id/ll_following">

                    <TextView
                        android:id="@+id/tv_follower_count"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/foreground"
                        android:fontFamily="@font/instagram_sans"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Followers"
                        android:textSize="12sp"
                        android:textColor="@color/foreground"
                        android:fontFamily="@font/instagram_sans"/>

                </LinearLayout>

                <!-- Following -->
                <LinearLayout
                    android:id="@+id/ll_following"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:clickable="true"
                    android:focusable="true"
                    app:layout_constraintTop_toTopOf="@id/iv_profile_image"
                    app:layout_constraintBottom_toBottomOf="@id/iv_profile_image"
                    app:layout_constraintStart_toEndOf="@id/ll_followers"
                    app:layout_constraintEnd_toEndOf="parent">

                    <TextView
                        android:id="@+id/tv_following_count"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/foreground"
                        android:fontFamily="@font/instagram_sans"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Following"
                        android:textSize="12sp"
                        android:textColor="@color/foreground"
                        android:fontFamily="@font/instagram_sans"/>

                </LinearLayout>

            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- Display Name -->
            <TextView
                android:id="@+id/tv_display_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/foreground"
                android:fontFamily="@font/instagram_sans"
                android:layout_marginTop="12dp"/>

            <!-- Bio -->
            <TextView
                android:id="@+id/tv_bio"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="13sp"
                android:textColor="@color/foreground"
                android:fontFamily="@font/instagram_sans"
                android:maxLines="3"
                android:layout_marginTop="2dp"/>

            <!-- Edit Profile / Follow button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_edit_profile"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="36dp"
                android:text="Edit Profile"
                android:textSize="13sp"
                android:fontFamily="@font/instagram_sans"
                android:visibility="gone"
                android:layout_marginTop="12dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_follow"
                android:layout_width="match_parent"
                android:layout_height="36dp"
                android:text="Follow"
                android:textSize="13sp"
                android:fontFamily="@font/instagram_sans"
                android:visibility="gone"
                android:layout_marginTop="12dp"/>

        </LinearLayout>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/border"/>

    </com.google.android.material.appbar.AppBarLayout>

    <!-- Posts Grid -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_posts"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"/>

        <!-- Empty State -->
        <LinearLayout
            android:id="@+id/empty_state"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:visibility="gone"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <ImageView
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:src="@drawable/ic_add_photo"
                app:tint="@color/border"
                android:layout_marginBottom="16dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="No posts yet"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/foreground"
                android:fontFamily="@font/instagram_sans"/>

            <TextView
                android:id="@+id/tv_empty_subtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Share your first photo or video"
                android:textSize="13sp"
                android:textColor="@color/muted_foreground"
                android:fontFamily="@font/instagram_sans"
                android:gravity="center"
                android:layout_marginTop="6dp"/>

            <!-- Only show on own profile -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_create_first_post"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Create Post"
                android:fontFamily="@font/instagram_sans"
                android:visibility="gone"
                android:layout_marginTop="20dp"
                app:cornerRadius="20dp"/>

        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>