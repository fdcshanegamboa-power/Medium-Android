<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Base.Theme.Connect" parent="Theme.Material3.Light.NoActionBar">

        <!-- Primary -->
        <item name="colorPrimary">@color/purple_500</item>
        <item name="colorPrimaryVariant">@color/purple_600</item>
        <item name="colorOnPrimary">@color/white</item>

        <!-- Secondary -->
        <item name="colorSecondary">@color/purple_300</item>
        <item name="colorSecondaryVariant">@color/purple_400</item>
        <item name="colorOnSecondary">@color/white</item>

        <!-- Background -->
        <item name="android:colorBackground">@color/background</item>
        <item name="colorSurface">@color/surface</item>
        <item name="colorOnSurface">@color/foreground</item>
        <item name="colorSurfaceVariant">@color/surface_variant</item>

        <!-- Error -->
        <item name="colorError">@color/error</item>
        <item name="colorOnError">@color/white</item>

        <!-- Status bar -->
        <item name="android:statusBarColor">@color/background</item>
        <item name="android:windowLightStatusBar">true</item>

    </style>

    <style name="Theme.Connect" parent="Base.Theme.Connect"/>
    <style name="NavActiveIndicator">
        <item name="android:color">@color/purple_800</item>
        <item name="shapeAppearance">@style/NavIndicatorShape</item>
    </style>

    <style name="NavIndicatorShape">
        <item name="cornerSize">50%</item>
    </style>
</resources>